# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=yourpassword
DB_NAME=weekly_reports

# JWT secret — use any long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# How long a JWT token stays valid (optional — defaults to 7d)
JWT_EXPIRES_IN=7d

# Groq API key — get a free key at https://console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here
# Groq model to use (optional — defaults to llama-3.3-70b-versatile, free tier)
# Other options: llama-3.1-8b-instant (faster), llama3-70b-8192
GROQ_MODEL=llama-3.3-70b-versatile

# App port (optional, defaults to 3000)
PORT=3000

# Environment — controls DB sync and SQL logging (development | production | test)
NODE_ENV=development

# Base URL for building email links (verification URL is APP_URL/api/auth/verify-email?token=...)
APP_URL=http://localhost:3000

# IANA timezone for all date/week calculations — change if your team is in a different zone
APP_TIMEZONE=Asia/Colombo

# Admin seed — set all three to auto-create the ADMIN account on first startup.
# Leave blank to skip seeding (admin can also be created manually via psql).
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisStrongPassword1!
ADMIN_NAME=System Admin

# SMTP email settings — optional; if SMTP_HOST is not set, verification links are printed to the
# console instead (useful for local dev). For production, use any SMTP provider (e.g. Gmail,
# Mailgun, SendGrid) or a dev sandbox like Mailtrap (https://mailtrap.io).
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@weeklyreports.dev
